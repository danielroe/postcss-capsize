{
  "name": "postcss-capsize",
  "version": "0.4.2",
  "packageManager": "pnpm@11.5.2",
  "description": "PostCSS plugin to inject capsize font metrics",
  "author": {
    "name": "Daniel Roe",
    "email": "daniel@roe.dev",
    "url": "https://github.com/danielroe"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielroe/postcss-capsize.git"
  },
  "keywords": [
    "postcss",
    "css",
    "postcss-plugin",
    "font",
    "capsize",
    "metrics"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "!**/*.map",
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsdown",
    "lint": "pnpm eslint",
    "prepack": "tsdown",
    "prepare": "simple-git-hooks && pnpm build",
    "prepublishOnly": "pnpm lint && pnpm test",
    "release": "bumpp && npm publish",
    "test": "pnpm test:unit",
    "test:unit": "vitest"
  },
  "peerDependencies": {
    "postcss": "^8.5.15"
  },
  "dependencies": {
    "@capsizecss/core": "^4.1.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.1",
    "lint-staged": "^17.0.7",
    "postcss": "^8.5.15",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "lintStaged": {
    "*.{js,ts,json,md,yaml,yml}": [
      "npx eslint --fix"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  }
}
